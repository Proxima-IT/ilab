{
    "openapi": "3.0.0",
    "info": {
        "title": "iLab EdTech API Documentation",
        "description": "Versioned REST API documentation for the iLab React Web SPA and Android/iOS mobile applications.",
        "contact": {
            "name": "Proxima IT",
            "email": "admin@yourdomain.com"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Local Development Server"
        },
        {
            "url": "https://dev-api.yourdomain.com",
            "description": "Development Server"
        },
        {
            "url": "https://api.yourdomain.com",
            "description": "Production Server"
        }
    ],
    "paths": {
        "/api/v1/auth/register": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Register a new student",
                "description": "Phone number is required. Email is optional. Registration creates an unverified account and sends phone OTP.",
                "operationId": "b9e746d77661fb8df55d0ac63e1ece77",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "phone",
                                    "password",
                                    "password_confirmation",
                                    "device_id",
                                    "platform"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "01700000000"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "john@gmail.com",
                                        "nullable": true
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "SecurePass123!"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "SecurePass123!"
                                    },
                                    "device_id": {
                                        "type": "string",
                                        "example": "web-browser-uuid-123"
                                    },
                                    "platform": {
                                        "type": "string",
                                        "example": "web",
                                        "enum": [
                                            "web",
                                            "android",
                                            "ios"
                                        ]
                                    },
                                    "fcm_token": {
                                        "type": "string",
                                        "example": "firebase-token",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Registration successful"
                    },
                    "409": {
                        "description": "Account exists but phone verification is pending"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/v1/auth/login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Login with phone/email and password",
                "description": "User can login with phone or email. Phone-first accounts must verify phone before token is issued.",
                "operationId": "a7997e7c1e3bfed64d4e56de82415931",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "login",
                                    "password",
                                    "portal",
                                    "device_id",
                                    "platform"
                                ],
                                "properties": {
                                    "login": {
                                        "type": "string",
                                        "example": "01700000000"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "SecurePass123!"
                                    },
                                    "portal": {
                                        "type": "string",
                                        "example": "student",
                                        "enum": [
                                            "admin",
                                            "student"
                                        ]
                                    },
                                    "device_id": {
                                        "type": "string",
                                        "example": "web-browser-uuid-123"
                                    },
                                    "platform": {
                                        "type": "string",
                                        "example": "web",
                                        "enum": [
                                            "web",
                                            "android",
                                            "ios"
                                        ]
                                    },
                                    "fcm_token": {
                                        "type": "string",
                                        "example": null,
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful"
                    },
                    "403": {
                        "description": "Phone verification required or unauthorized portal access"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/v1/auth/google": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Google registration/login",
                "description": "Google users can login without phone verification, but profile remains incomplete until phone is added and verified.",
                "operationId": "99255feaa276a172f099d622bac7eaab",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "id_token",
                                    "portal",
                                    "device_id",
                                    "platform"
                                ],
                                "properties": {
                                    "id_token": {
                                        "type": "string",
                                        "example": "eyJhbGciOiJSUzI1NiIsImtpZCI6..."
                                    },
                                    "portal": {
                                        "type": "string",
                                        "example": "student",
                                        "enum": [
                                            "student"
                                        ]
                                    },
                                    "device_id": {
                                        "type": "string",
                                        "example": "web-browser-uuid-123"
                                    },
                                    "platform": {
                                        "type": "string",
                                        "example": "web",
                                        "enum": [
                                            "web",
                                            "android",
                                            "ios"
                                        ]
                                    },
                                    "fcm_token": {
                                        "type": "string",
                                        "example": "firebase-token",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful response"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/v1/auth/logout": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Logout user and revoke current token",
                "operationId": "f6b8957b4c0b25636613a9f0512a8ba9",
                "responses": {
                    "200": {
                        "description": "Logged out successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/blog-posts": {
            "get": {
                "tags": [
                    "Blog"
                ],
                "summary": "List published blog posts",
                "operationId": "0c658a50b7b4e77330ddc8714078fda2",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 12,
                            "maximum": 24,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Blog posts retrieved successfully"
                    }
                }
            }
        },
        "/api/v1/blog-posts/{slug}": {
            "get": {
                "tags": [
                    "Blog"
                ],
                "summary": "Get blog post details",
                "operationId": "4db969980e67501f49b4deeb2b06a0d9",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "mobile-repairing-career-guide"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Blog post retrieved successfully"
                    },
                    "404": {
                        "description": "Blog post not found"
                    }
                }
            }
        },
        "/api/v1/student/certificates": {
            "get": {
                "tags": [
                    "Student Certificates"
                ],
                "summary": "List student certificates",
                "description": "Returns real certificates for the authenticated student. Eligible certificates are created automatically when course progress reaches 90%.",
                "operationId": "38c86c942a6bae97fda3051c3e0ee1f5",
                "responses": {
                    "200": {
                        "description": "Certificates retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "properties": {
                                                "certificates": {
                                                    "type": "array",
                                                    "items": {
                                                        "properties": {
                                                            "id": {
                                                                "type": "string",
                                                                "example": "9b3f7c2d-1234-4bcd-a456-123456789abc"
                                                            },
                                                            "verification_code": {
                                                                "type": "string",
                                                                "example": "ILAB-2026-AB12CD34"
                                                            },
                                                            "authorized_signatory_name": {
                                                                "type": "string",
                                                                "example": "Authorized Signature"
                                                            },
                                                            "authorized_signatory_title": {
                                                                "type": "string",
                                                                "example": "iLab BD"
                                                            },
                                                            "eligible_progress": {
                                                                "type": "integer",
                                                                "example": 90
                                                            },
                                                            "issued_at": {
                                                                "type": "string",
                                                                "format": "date-time"
                                                            }
                                                        },
                                                        "type": "object"
                                                    }
                                                },
                                                "eligible_progress": {
                                                    "type": "integer",
                                                    "example": 90
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Certificates retrieved successfully."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated"
                    },
                    "403": {
                        "description": "Unauthorized certificate access"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/courses": {
            "get": {
                "tags": [
                    "Course Catalog"
                ],
                "summary": "List all published courses",
                "description": "Returns a paginated list of published courses for the storefront.",
                "operationId": "3522f88b734e2061541a8dbd0b6be53c",
                "responses": {
                    "200": {
                        "description": "List of courses retrieved"
                    }
                }
            }
        },
        "/api/v1/courses/{slug}": {
            "get": {
                "tags": [
                    "Course Catalog"
                ],
                "summary": "Get full course details by slug",
                "description": "Returns course details including section and lesson hierarchy. Paid video URLs are hidden from guests.",
                "operationId": "0c45ecab08c0edb745cbb12ced0b8e90",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "description": "The course slug",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Course details retrieved"
                    },
                    "404": {
                        "description": "Course not found"
                    }
                }
            }
        },
        "/api/v1/events": {
            "get": {
                "tags": [
                    "Events"
                ],
                "summary": "List published events",
                "description": "Returns published events with registration counts and finished status.",
                "operationId": "1845dc9126717378ecce57f9863a2775",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 12,
                            "maximum": 24,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Events retrieved successfully"
                    }
                }
            }
        },
        "/api/v1/events/{slug}": {
            "get": {
                "tags": [
                    "Events"
                ],
                "summary": "Get event details",
                "description": "Returns a single published event by slug.",
                "operationId": "d4ff97a4c7fe55512b7b95819418c0d9",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "free-mobile-repairing-workshop"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Event retrieved successfully"
                    },
                    "404": {
                        "description": "Event not found"
                    }
                }
            }
        },
        "/api/v1/events/{slug}/registrations": {
            "post": {
                "tags": [
                    "Events"
                ],
                "summary": "Register for an event",
                "description": "Creates an event registration. Finished events cannot receive registrations.",
                "operationId": "0f012586c8b31bc08b52499532168ed4",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "free-mobile-repairing-workshop"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "full_name",
                                    "email",
                                    "phone",
                                    "why_want_to_learn"
                                ],
                                "properties": {
                                    "full_name": {
                                        "type": "string",
                                        "example": "Md Hasan"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "hasan@example.com"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "01700000000"
                                    },
                                    "education": {
                                        "type": "string",
                                        "example": "Diploma in Engineering",
                                        "nullable": true
                                    },
                                    "profession": {
                                        "type": "string",
                                        "example": "Student",
                                        "nullable": true
                                    },
                                    "why_want_to_learn": {
                                        "type": "string",
                                        "example": "I want to build a mobile repairing business."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Registration completed successfully"
                    },
                    "400": {
                        "description": "Event registration is closed"
                    },
                    "409": {
                        "description": "Already registered with this email"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/api/v1/learn/courses/{slug}/syllabus": {
            "get": {
                "tags": [
                    "Learning Experience"
                ],
                "summary": "Get full course syllabus",
                "description": "Returns sections and lessons for enrolled students. Direct video URLs are not exposed.",
                "operationId": "e452e2026ef23de381015e9405141894",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "description": "Course slug",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Syllabus retrieved successfully"
                    },
                    "403": {
                        "description": "Not enrolled in this course"
                    },
                    "404": {
                        "description": "Course not found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/learn/lessons/{id}/complete": {
            "post": {
                "tags": [
                    "Learning Experience"
                ],
                "summary": "Mark a lesson as completed",
                "description": "Marks a lesson complete only if the student is enrolled and has watched enough of the lesson.",
                "operationId": "e881eab91c08faea91134f3d4f8dd228",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Lesson ID",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Progress updated successfully"
                    },
                    "403": {
                        "description": "Not enrolled or watch threshold not met"
                    },
                    "404": {
                        "description": "Lesson not found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/learn/lessons/{id}/time": {
            "put": {
                "tags": [
                    "Learning Experience"
                ],
                "summary": "Sync video player watch time",
                "description": "Frontend video player should call this every 10-15 seconds to save resume point.",
                "operationId": "da9861bcfdf092b02c0809f0a6615ec5",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Lesson ID",
                        "required": true
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "watch_seconds"
                                ],
                                "properties": {
                                    "watch_seconds": {
                                        "type": "integer",
                                        "example": 145
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Watch time synced successfully"
                    },
                    "403": {
                        "description": "Not enrolled"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/checkout/init": {
            "post": {
                "tags": [
                    "Checkout & Enrollment"
                ],
                "summary": "Initialize UddoktaPay Checkout",
                "description": "Calculates the final price securely and returns the UddoktaPay payment URL. If the course is 100% free (via coupon or base price), it enrolls the user instantly.",
                "operationId": "b25513a3f79c7b58084daf284e3f54aa",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "course_id"
                                ],
                                "properties": {
                                    "course_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "coupon_code": {
                                        "type": "string",
                                        "example": "REACT50"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Checkout initialized successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "properties": {
                                                "is_free": {
                                                    "type": "boolean",
                                                    "example": false
                                                },
                                                "payment_url": {
                                                    "type": "string",
                                                    "example": "https://pay.uddoktapay.com/checkout/12345"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid coupon or already enrolled"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/health-check": {
            "get": {
                "tags": [
                    "System"
                ],
                "summary": "API Health Check",
                "description": "Check if the backend API server is running.",
                "operationId": "91d0c2203a1efb282f8c3f5ad4652202",
                "responses": {
                    "200": {
                        "description": "Server is healthy.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "properties": {
                                                "status": {
                                                    "type": "string",
                                                    "example": "healthy"
                                                },
                                                "service": {
                                                    "type": "string",
                                                    "example": "iLab API"
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "API is running."
                                        },
                                        "errors": {
                                            "type": "string",
                                            "example": null,
                                            "nullable": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": []
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Laravel Sanctum Bearer Token. Example: Bearer {access_token}",
                "scheme": "bearer"
            }
        }
    },
