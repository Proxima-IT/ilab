{
    "openapi": "3.0.0",
    "info": {
        "title": "E-Learning Platform API Documentation",
        "description": "Backend API endpoints for React Web and Flutter Mobile application.",
        "contact": {
            "email": "admin@yourdomain.com"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Local Development Server"
        },
        {
            "url": "https://dev-api.yourdomain.com",
            "description": "Development Server"
        },
        {
            "url": "https://api.yourdomain.com",
            "description": "Production Server"
        }
    ],
    "paths": {
        "/api/v1/auth/register": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Register a new student",
                "description": "Creates a new student account. Emails/SMS are dispatched via queues to maintain <300ms response.",
                "operationId": "b9e746d77661fb8df55d0ac63e1ece77",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "device_id",
                                    "platform"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "John Doe"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "student@domain.com"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "+8801700000000"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "SecurePass123!"
                                    },
                                    "device_id": {
                                        "type": "string",
                                        "example": "device-uuid-1234"
                                    },
                                    "platform": {
                                        "type": "string",
                                        "example": "web"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "User registered successfully"
                    },
                    "422": {
                        "description": "Validation Errors"
                    }
                }
            }
        },
        "/api/v1/auth/login": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Login for both Admin and Students",
                "description": "Validates credentials and enforces domain/role strictness.",
                "operationId": "a7997e7c1e3bfed64d4e56de82415931",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password",
                                    "portal",
                                    "device_id",
                                    "platform"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "example": "admin@domainname.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "password"
                                    },
                                    "portal": {
                                        "type": "string",
                                        "example": "admin",
                                        "enum": [
                                            "admin",
                                            "student"
                                        ]
                                    },
                                    "device_id": {
                                        "type": "string",
                                        "example": "browser-uuid-1234"
                                    },
                                    "platform": {
                                        "type": "string",
                                        "example": "web"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful"
                    },
                    "401": {
                        "description": "Invalid credentials"
                    },
                    "403": {
                        "description": "Unauthorized access to this portal"
                    }
                }
            }
        },
        "/api/v1/auth/logout": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Logout user and revoke token",
                "operationId": "f6b8957b4c0b25636613a9f0512a8ba9",
                "responses": {
                    "200": {
                        "description": "Logged out successfully"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/courses": {
            "get": {
                "tags": [
                    "Course Catalog"
                ],
                "summary": "List all published courses",
                "description": "Returns a paginated list of published courses for the storefront.",
                "operationId": "3522f88b734e2061541a8dbd0b6be53c",
                "responses": {
                    "200": {
                        "description": "List of courses retrieved"
                    }
                }
            }
        },
        "/api/v1/courses/{slug}": {
            "get": {
                "tags": [
                    "Course Catalog"
                ],
                "summary": "Get full course details by slug",
                "description": "Returns course details including the section and lesson hierarchy. Paid video URLs are hidden from guests.",
                "operationId": "0c45ecab08c0edb745cbb12ced0b8e90",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "description": "The course slug (e.g., complete-laravel-react-bootcamp)",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Course details retrieved"
                    },
                    "404": {
                        "description": "Course not found"
                    }
                }
            }
        },
        "/api/v1/learn/courses/{slug}/syllabus": {
            "get": {
                "tags": [
                    "Learning Experience"
                ],
                "summary": "Get full course syllabus with playable videos",
                "description": "Returns the sections and lessons. Only enrolled students will see the actual video_url for paid lessons.",
                "operationId": "e452e2026ef23de381015e9405141894",
                "parameters": [
                    {
                        "name": "slug",
                        "in": "path",
                        "description": "Course slug",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Syllabus retrieved successfully"
                    },
                    "403": {
                        "description": "Not enrolled in this course"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/auth/forgot-password": {
            "post": {
                "tags": [
                    "Password Recovery"
                ],
                "summary": "Request Password Reset OTP",
                "description": "Sends a 6-digit OTP to the provided email or phone number.",
                "operationId": "093d7dcd3aef205b2df8b7ee0265d446",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "identifier"
                                ],
                                "properties": {
                                    "identifier": {
                                        "type": "string",
                                        "example": "student@domain.com or +8801700000000"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "OTP Sent successfully (or silently ignored if user does not exist)"
                    }
                }
            }
        },
        "/api/v1/auth/reset-password": {
            "post": {
                "tags": [
                    "Password Recovery"
                ],
                "summary": "Reset Password using OTP",
                "description": "Verifies the OTP and updates the user's password.",
                "operationId": "53e6ad1f6dee291101a79f86a2dd1c1c",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "identifier",
                                    "otp",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "identifier": {
                                        "type": "string",
                                        "example": "student@domain.com"
                                    },
                                    "otp": {
                                        "type": "string",
                                        "example": "123456"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "NewSecurePass123!"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "NewSecurePass123!"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Password reset successfully"
                    },
                    "400": {
                        "description": "Invalid or expired OTP"
                    }
                }
            }
        },
        "/api/v1/learn/lessons/{id}/complete": {
            "post": {
                "tags": [
                    "Learning Experience"
                ],
                "summary": "Mark a lesson as completed",
                "description": "Records the lesson as finished and returns the updated total course progress percentage.",
                "operationId": "e881eab91c08faea91134f3d4f8dd228",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Lesson ID",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Progress updated successfully"
                    },
                    "403": {
                        "description": "Not enrolled"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/learn/lessons/{id}/time": {
            "put": {
                "tags": [
                    "Learning Experience"
                ],
                "summary": "Sync video player watch time",
                "description": "The frontend video player should call this silently every 10-15 seconds to save the user's resume point.",
                "operationId": "da9861bcfdf092b02c0809f0a6615ec5",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "Lesson ID",
                        "required": true
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "watch_seconds"
                                ],
                                "properties": {
                                    "watch_seconds": {
                                        "description": "Current video timestamp in seconds",
                                        "type": "integer",
                                        "example": 145
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Watch time synced successfully"
                    },
                    "403": {
                        "description": "Not enrolled"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/student/profile": {
            "get": {
                "tags": [
                    "Student Profile"
                ],
                "summary": "Get Student Profile & Dashboard Data",
                "description": "Returns the authenticated student's profile along with their enrolled courses and progress.",
                "operationId": "ab016aa14ac89526a467edca803e25f4",
                "responses": {
                    "200": {
                        "description": "Profile retrieved successfully"
                    },
                    "401": {
                        "description": "Unauthenticated"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "put": {
                "tags": [
                    "Student Profile"
                ],
                "summary": "Update Student Profile",
                "operationId": "247a56793cc8233d1134d243d2e0396c",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "bio": {
                                        "type": "string"
                                    },
                                    "district": {
                                        "type": "string"
                                    },
                                    "education_level": {
                                        "type": "string"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profile updated successfully"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/v1/checkout/init": {
            "post": {
                "tags": [
                    "Checkout & Enrollment"
                ],
                "summary": "Initialize UddoktaPay Checkout",
                "description": "Calculates the final price securely and returns the UddoktaPay payment URL. If the course is 100% free (via coupon or base price), it enrolls the user instantly.",
                "operationId": "b25513a3f79c7b58084daf284e3f54aa",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "course_id"
                                ],
                                "properties": {
                                    "course_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "coupon_code": {
                                        "type": "string",
                                        "example": "REACT50"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Checkout initialized successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "properties": {
                                                "is_free": {
                                                    "type": "boolean",
                                                    "example": false
                                                },
                                                "payment_url": {
                                                    "type": "string",
                                                    "example": "https://pay.uddoktapay.com/checkout/12345"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid coupon or already enrolled"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/health-check": {
            "get": {
                "tags": [
                    "System"
                ],
                "summary": "API Health Check",
                "description": "Check if the backend API server is running smoothly.",
                "operationId": "0debfe94c65f782b55a44d7662c39b4a",
                "responses": {
                    "200": {
                        "description": "Server is healthy and up!"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sanctum": {
                "type": "http",
                "description": "Enter your Sanctum token to access secured endpoints",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Authentication",
            "description": "Endpoints for user registration, login, and device tracking"
        },
        {
            "name": "Course Catalog",
            "description": "Public endpoints for browsing the course catalog"
        },
        {
            "name": "Learning Experience"
        },
        {
            "name": "Password Recovery",
            "description": "Endpoints for requesting OTPs and resetting user passwords"
        },
        {
            "name": "Student Profile",
            "description": "Endpoints for student dashboard and profile management"
        },
        {
            "name": "Checkout & Enrollment",
            "description": "Secure course purchasing using UddoktaPay"
        },
        {
            "name": "System",
            "description": "System"
        }
    ]
}